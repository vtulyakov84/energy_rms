CONTAINER_RESTAPI_NAME=rms-service-rest-api
CONTAINER_WEB_NAME=rms-service-web
CONTAINER_DB_NAME=rms-service-db

DB_HOST=localhost
DB_PORT=5432
DB_NAME=energy_rms
